if _G.ScriptRunning then
    _G.ScriptRunning = false
    task.wait(0.2)
end

-- [ ⚡ CLEANUP GLOBAL ⚡ ]
local function CleanupLuvHubConnections()
    if type(_G.LuvHubConnections) == "table" then
        for _, conn in pairs(_G.LuvHubConnections) do
            pcall(function() conn:Disconnect() end)
        end
    end
    _G.LuvHubConnections = {}
    
    if type(_G.StreamerConns) == "table" then
        for _, conn in pairs(_G.StreamerConns) do
            pcall(function() conn:Disconnect() end)
        end
    end
    _G.StreamerConns = {}
end
CleanupLuvHubConnections()

