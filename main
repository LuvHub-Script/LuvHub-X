-- [ ⚡ TAB OPTIMASI (FPS BOOST & ANTI-LAG) ⚡ ]
local OptTab = CreateTab("Optimasi", "🚀", 8)

local function RunFPSBoost()
    local Lighting = game:GetService("Lighting")
    local Terrain = workspace:FindFirstChildOfClass("Terrain")

    -- 1. Optimasi Lighting & Shadow
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.ShadowSoftness = 0
    if sethiddenproperty then
        pcall(function() sethiddenproperty(Lighting, "Technology", Enum.Technology.Compatibility) end)
    end
    for _, v in pairs(Lighting:GetChildren()) do
        if v:IsA("PostEffect") then v.Enabled = false end
    end

    -- 2. Optimasi Air Map (Sangat penting untuk IndoStrike)
    if Terrain then
        Terrain.WaterWaveSize = 0
        Terrain.WaterWaveSpeed = 0
        Terrain.WaterReflectance = 0
        Terrain.WaterTransparency = 1
        Terrain.Decoration = false
    end

    -- 3. Potato Mode (Ubah ke SmoothPlastic & Hapus Tekstur)
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            obj.Material = Enum.Material.SmoothPlastic
            obj.Reflectance = 0
            obj.CastShadow = false
        elseif obj:IsA("Decal") or obj:IsA("Texture") then
            obj.Transparency = 1
        elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") then
            obj.Lifetime = NumberRange.new(0)
        end
    end

    -- 4. Cegah render efek/part baru yang dimunculkan server
    local optConn = workspace.DescendantAdded:Connect(function(obj)
        if obj:IsA("BasePart") then
            obj.Material = Enum.Material.SmoothPlastic
            obj.CastShadow = false
        elseif obj:IsA("ParticleEmitter") then
            obj.Lifetime = NumberRange.new(0)
        end
    end)
    table.insert(_G.LuvHubConnections, optConn)
end

CreateSection(OptTab, "Performance Boost", "Label")
CreateSection(OptTab, "Potato Mode (Max FPS)", "Button", function()
    RunFPSBoost()
    LuvHubNotify({
        Title = "🚀 FPS Boost Aktif",
        Text = "Grafik berhasil dioptimalkan! Map sekarang sangat ringan.",
        Duration = 3
    })
end, "Mokel")

CreateSection(OptTab, "Ultra AFK (True Anti-Lag)", "Label")
CreateSection(OptTab, "3D Rendering", "Toggle", function(v)
    pcall(function()
        game:GetService("RunService"):Set3dRenderingEnabled(not v)
    end)
    LuvHubNotify({ 
        Title = v and "🛑 Rendering OFF" or "🌍 Rendering ON", 
        Text = v and "3D World dimatikan! CPU & GPU 0% usage." or "3D World kembali dirender.", 
        Duration = 3 
    })
end)

local SettingsTab = CreateTab("Settings", "⚙️", 9)
CreateSection(SettingsTab, "Tampilan", "Label")

local function ApplyTheme(TemaName)
    local t = ThemePalettes[TemaName] or ThemePalettes["Default Blue"]
    Colors.Accent = t.Accent
    Title.TextColor3 = t.Accent
    
    local stroke = ToggleBtn:FindFirstChild("UIStroke")
    if stroke then stroke.Color = t.Accent end
    
    for _, v in pairs(MainFrame:GetChildren()) do
        if v:IsA("UIGradient") then
            v.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0.00, t.Grad1), 
                ColorSequenceKeypoint.new(1.00, t.Grad2)
            }
        end
    end
    for _, v in pairs(MainFrame:GetDescendants()) do
        if v:IsA("UIGradient") and v.Parent and v.Parent:IsA("UIStroke") then
            v.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 0, 0)),
                ColorSequenceKeypoint.new(0.25, t.Accent),
                ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 0, 0)),
                ColorSequenceKeypoint.new(0.75, t.Accent),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 0, 0))
            }
        end
    end
    for _, tab in pairs(Tabs) do
        if tab.Page.Visible then tab.Ico.TextColor3 = t.Accent end
    end
    for _, obj in pairs(Content:GetDescendants()) do
        if obj:IsA("TextButton") then
            if obj.Size == UDim2.new(0, 80, 0, 18) then
                obj.BackgroundColor3 = t.Accent
            elseif obj.Size == UDim2.new(0, 28, 0, 14) and obj.BackgroundColor3 ~= Color3.fromRGB(60, 60, 60) then
                obj.BackgroundColor3 = t.Accent
            end
        elseif obj:IsA("Frame") then
            pcall(function()
                if obj.Size.Y.Scale == 1 and obj.Parent and obj.Parent:IsA("GuiObject") and obj.Parent.BackgroundColor3 == Color3.fromRGB(50, 50, 60) then
                    obj.BackgroundColor3 = t.Accent
                end
            end)
        elseif obj:IsA("TextLabel") then
            if obj.Text == ">" then
                obj.TextColor3 = t.Accent
            elseif (obj.Size == UDim2.new(0, 50, 0, 20) or obj.Size == UDim2.new(1, -10, 0, 18)) and obj.TextColor3 ~= Color3.fromRGB(180, 180, 180) then
                obj.TextColor3 = t.Accent
            end
        elseif obj:IsA("TextBox") then
            obj.TextColor3 = t.Accent
        elseif obj:IsA("UIStroke") then
            if obj.Transparency == 0.5 then
                obj.Color = t.Accent
            end
        end
    end
end

local TemaList = {"Default Blue", "Sunset Orange", "Matrix Green", "Blood Red"}
CreateSection(SettingsTab, "Tema GUI", "Choice", function(v) 
    _G.TemaDipilih = v 
    ApplyTheme(v)
end, TemaList)

