local function ClearStreamerConnections()
    if type(_G.StreamerConns) == "table" then
        for _, conn in pairs(_G.StreamerConns) do pcall(function() conn:Disconnect() end) end
    end
    _G.StreamerConns = {}
end

local function applyCensorLogic(obj)
    if not _G.StreamerMode then return end
    if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
        local LP = game:GetService("Players").LocalPlayer
        if not LP then return end
        local realName = LP.Name
        local realDisplay = LP.DisplayName
        
        local function doCensor()
            if obj.Text and (string.find(obj.Text, realName) or string.find(obj.Text, realDisplay)) then
                obj.Text = string.gsub(obj.Text, realName, _G.FakeName)
                obj.Text = string.gsub(obj.Text, realDisplay, _G.FakeName)
            end
        end
        
        doCensor()
        local conn = obj:GetPropertyChangedSignal("Text"):Connect(function()
            if _G.StreamerMode then doCensor() end
        end)
        if type(_G.StreamerConns) == "table" then table.insert(_G.StreamerConns, conn) end
    end
end

local function applyCensorToGui(gui)
    for _, v in pairs(gui:GetDescendants()) do applyCensorLogic(v) end
    local conn = gui.DescendantAdded:Connect(applyCensorLogic)
    if type(_G.StreamerConns) == "table" then table.insert(_G.StreamerConns, conn) end
end

