    [78632820802305] = "IndoStrike",
}

local currentPlaceId = game.PlaceId
local mapName = SupportedMaps[currentPlaceId]

task.spawn(function()
    if mapName then
        LuvHubNotify({
            Title = "✅ System: Supported",
            Text = "Map Terdeteksi: " .. mapName .. "!\nMenyiapkan Luv Hub X...",
            Duration = 5
        })
    else
        LuvHubNotify({
            Title = "❌ System: Unknown Map",
            Text = "Map (" .. tostring(currentPlaceId) .. ") tidak didukung.\nTetap memaksa memuat GUI...",
            Duration = 5
        })
    end
end)

local function AddGradient(Parent)
    local UIGradient = Instance.new("UIGradient")
    UIGradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0.00, Color3.fromRGB(10, 10, 20)), 
        ColorSequenceKeypoint.new(1.00, Color3.fromRGB(0, 60, 110))
    }
    UIGradient.Rotation = 45
    UIGradient.Parent = Parent
end

local function AddSpinningBorder(Parent)
    local Stroke = Instance.new("UIStroke")
    Stroke.Thickness = 3
    Stroke.Parent = Parent
    local Gradient = Instance.new("UIGradient")
    Gradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 0, 0)),
        ColorSequenceKeypoint.new(0.25, Colors.Accent),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 0, 0)),
        ColorSequenceKeypoint.new(0.75, Colors.Accent),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 0, 0))
    }
    Gradient.Parent = Stroke
    local conn = RunService.RenderStepped:Connect(function()
        if Parent and Parent.Parent then Gradient.Rotation = (Gradient.Rotation + 2) % 360 end
    end)
    table.insert(_G.LuvHubConnections, conn)
end

local function EksekusiJualIkan()
    local target = tonumber(_G.SellWeightTarget) or 100
    pcall(function()
        game:GetService("ReplicatedStorage").Economy.ToServer.SellUnder:FireServer(target)
    end)
end

local vfxCleaner = workspace.ChildAdded:Connect(function(child)
    if _G.ScriptRunning and _G.SkipVFX then
        local isTargetVFX = string.find(child.Name, "CatchVFX") 
                         or string.find(child.Name, "EpicVFX")
                         or string.find(child.Name, "SecretVFX")
                         or string.find(child.Name, "LegendVFX") 
        
        if isTargetVFX then
            if _G.SkipVFXTarget == "All" then
                task.wait()
                pcall(function() child:Destroy() end)
            elseif _G.SkipVFXTarget == "Me" then
                if string.find(child.Name, tostring(LocalPlayer.UserId)) then
                    task.wait()
                    pcall(function() child:Destroy() end)
                end
            end
        end
    end
end)
table.insert(_G.LuvHubConnections, vfxCleaner)

