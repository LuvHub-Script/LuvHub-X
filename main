-- [ ⚡ FUNGSI GLOBAL FISHING ⚡ ]

local cachedRodUUID = nil
local lastActiveTool = nil

local function getActiveRodUUID()
    local char = LocalPlayer.Character
    if not char then return nil end
    local activeTool = char:FindFirstChildOfClass("Tool")
    
    if not activeTool then 
        cachedRodUUID = nil 
        lastActiveTool = nil
        return nil 
    end

    if activeTool == lastActiveTool and cachedRodUUID then
        return cachedRodUUID
    end

    for _, v in pairs(getgc(true)) do
        if type(v) == "table" and rawget(v, "TOOL_ID") then
            if rawget(v, "tool") == activeTool then
                local cState = rawget(v, "ClientState")
                if type(cState) == "table" and rawget(cState, "equipped") == true then
                    cachedRodUUID = rawget(v, "TOOL_ID")
                    lastActiveTool = activeTool
                    return cachedRodUUID
                end
            end
        end
    end
    return nil
end

local function forceStopFishing()
    local uuid = getActiveRodUUID()
    if not uuid then return end
    pcall(function()
        if _G.LuvHubX_FishingState == "WAITING" then
            ReplicatedStorage.Fishing.ToServer.CancelPendingBite:FireServer(uuid)
        elseif _G.LuvHubX_FishingState == "MINIGAME" then
            ReplicatedStorage.Fishing.ToServer.ReelFinished:FireServer({duration = 0, result = "FAIL", insideRatio = 0}, uuid)
        end
        ReplicatedStorage.Fishing_RemoteRetract:FireServer(uuid)
    end)
    _G.LuvHubX_FishingState = "IDLE"
end

-- [ ⚡ LOGIKA Advanced AUTO FISH (BARU) ⚡ ]
local function FishCycleUB()
    local uuid = getActiveRodUUID()
    if not uuid then return end
    task.spawn(function()
        ReplicatedStorage.Fishing_RemoteThrow:FireServer(1.0, uuid)
    end)
    task.wait(EngineUB.CompleteDelay)
    task.spawn(function()
        ReplicatedStorage.Fishing.ToServer.MinigameStarted:FireServer(uuid)
        task.wait(0)
        ReplicatedStorage.Fishing.ToServer.ReelFinished:FireServer({
            duration = EngineUB.CompleteDelay,
            result = "SUCCESS",
            insideRatio = 1.0
        }, uuid)
    end)
    task.wait(EngineUB.CancelDelay)
end

local function MainLoopUB()
    StatsUB.Loop = 0
    while EngineUB.Active and _G.ScriptRunning do
        for i = 1, EngineUB.AdvancedCount do
            if not EngineUB.Active or not _G.ScriptRunning then break end
            FishCycleUB()
            task.wait(0)
        end
        StatsUB.Loop = StatsUB.Loop + 1
        if StatsUB.Loop >= EngineUB.RecoveryEvery then
            task.spawn(function()
                local uuid = getActiveRodUUID()
                if uuid then
                    ReplicatedStorage.Fishing.ToServer.CancelPendingBite:FireServer(uuid)
                    ReplicatedStorage.Fishing_RemoteRetract:FireServer(uuid)
                end
            end)
            StatsUB.Loop = 0
        end
        task.wait(EngineUB.Throttle)
    end
end

local function StartEngineUB()
    if EngineUB.Active then return end
    EngineUB.Active = true
    task.spawn(MainLoopUB)
end

local function StopEngineUB()
    if not EngineUB.Active then return end
    EngineUB.Active = false
    local uuid = getActiveRodUUID()
    if uuid then
        ReplicatedStorage.Fishing.ToServer.CancelPendingBite:FireServer(uuid)
        ReplicatedStorage.Fishing_RemoteRetract:FireServer(uuid)
    end
end

local retractConn = ReplicatedStorage.Fishing_RemoteRetract.OnClientEvent:Connect(function()
    if not EngineUB.Active or not _G.ScriptRunning then return end
    task.spawn(function()
        task.wait(EngineUB.CompleteDelay)
        local uuid = getActiveRodUUID()
        if uuid then
            ReplicatedStorage.Fishing.ToServer.ReelFinished:FireServer({
                duration = EngineUB.CompleteDelay,
                result = "SUCCESS",
                insideRatio = 1.0
            }, uuid)
            task.wait(EngineUB.CancelDelay)
            ReplicatedStorage.Fishing.ToServer.CancelPendingBite:FireServer(uuid)
        end
    end)
end)
table.insert(_G.LuvHubConnections, retractConn)

-- [ ⚡ SISTEM GACOR & MULTIPLIER (SATU PINTU HOOK - OPTIMIZED) ⚡ ]
local GACORConfig = { Active = false, SpamCount = 1 }
local MultiplierConfig = { Active = false, SpamCount = 1 }

if type(hookmetamethod) == "function" then
    -- Mencegah Double Hooking & mengamankan dari Garbage Collection
    if not getgenv().LuvHub_Hooked then
        getgenv().LuvHub_Hooked = true
        
        getgenv().LuvHub_OldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            local method = getnamecallmethod()

            if method == "FireServer" and typeof(self) == "Instance" and self.Name == "ReelFinished" then
                if not checkcaller() then
                    local args = {...}
                    
                    if GACORConfig.Active then
                        task.spawn(function()
                            task.wait(0.05)
                            for i = 1, GACORConfig.SpamCount do
                                pcall(function()
                                    getgenv().LuvHub_OldNamecall(self, unpack(args))
                                end)
                            end
                        end)
                    end
                    
                    if MultiplierConfig.Active then
                        task.spawn(function()
                            task.wait(0.05)
                            for i = 1, MultiplierConfig.SpamCount do
                                getgenv().LuvHub_OldNamecall(self, unpack(args))
                            end
                        end)
                    end
                end
            end
            
            return getgenv().LuvHub_OldNamecall(self, ...)
        end))
    end
else
    task.spawn(function()
        task.wait(6)
        LuvHubNotify({ 
            Title = "⚠️ Warning", 
            Text = "Executor tidak mendukung Bypass System.", 
            Duration = 5 
        })
    end)
end


