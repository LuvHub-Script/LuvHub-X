local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")

local MultiplierConfig = {
    Active    = false,
    SpamCount = 1
}

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local method = getnamecallmethod()

    if not checkcaller() and method == "FireServer" and typeof(self) == "Instance" and self.Name == "ReelFinished" then
        if MultiplierConfig.Active then
            local args = {...}
            task.spawn(function()
                task.wait(0.05)
                for i = 1, MultiplierConfig.SpamCount do
                    self:FireServer(unpack(args))
                end
            end)
        end
    end
    
    return oldNamecall(self, ...)
end))

local targetGui = (gethui and gethui()) or (pcall(function() return CoreGui.Name end) and CoreGui) or Players.LocalPlayer:WaitForChild("PlayerGui")

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "FishMultiplierGUI"
screenGui.ResetOnSpawn = false
screenGui.Parent = targetGui

local frame = Instance.new("Frame", screenGui)
frame.Size = UDim2.new(0, 150, 0, 80)
frame.Position = UDim2.new(0.5, -75, 0, 20)
frame.BorderSizePixel = 0
frame.Active = true
Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)

local gradient = Instance.new("UIGradient", frame)
gradient.Color = ColorSequence.new({
    ColorSequenceKeypoint.new(0, Color3.fromRGB(15, 20, 30)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 70, 140))
})
gradient.Rotation = 45

local toggleBtn = Instance.new("TextButton", frame)
toggleBtn.Size = UDim2.new(1, -20, 0, 35)
toggleBtn.Position = UDim2.new(0, 10, 0, 10)
toggleBtn.Text = "MULTIPLIER: OFF"
toggleBtn.Font = Enum.Font.GothamBold
toggleBtn.TextSize = 12
toggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
toggleBtn.TextColor3 = Color3.new(1, 1, 1)
Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 6)

toggleBtn.MouseButton1Click:Connect(function()
    MultiplierConfig.Active = not MultiplierConfig.Active
    if MultiplierConfig.Active then
        toggleBtn.Text = "MULTIPLIER: ON"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 90)
    else
        toggleBtn.Text = "MULTIPLIER: OFF"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    end
end)

local spamLabel = Instance.new("TextLabel", frame)
spamLabel.Size = UDim2.new(0.6, -10, 0, 20)
spamLabel.Position = UDim2.new(0, 10, 0, 50)
spamLabel.Text = "Spam/Catch:"
spamLabel.Font = Enum.Font.Gotham
spamLabel.TextSize = 12
spamLabel.TextColor3 = Color3.new(0.9, 0.9, 0.9)
spamLabel.BackgroundTransparency = 1
spamLabel.TextXAlignment = Enum.TextXAlignment.Left

local spamBox = Instance.new("TextBox", frame)
spamBox.Size = UDim2.new(0.4, -10, 0, 20)
spamBox.Position = UDim2.new(0.6, 0, 0, 50)
spamBox.Text = tostring(MultiplierConfig.SpamCount)
spamBox.Font = Enum.Font.GothamBold
spamBox.TextSize = 12
spamBox.BackgroundColor3 = Color3.fromRGB(25, 30, 40)
spamBox.TextColor3 = Color3.new(1, 1, 1)
Instance.new("UICorner", spamBox).CornerRadius = UDim.new(0, 4)

spamBox.FocusLost:Connect(function()
    local val = tonumber(spamBox.Text)
    if val then
        MultiplierConfig.SpamCount = math.clamp(math.floor(val), 1, 50)
    end
    spamBox.Text = tostring(MultiplierConfig.SpamCount)
end)

local dragging = false
local dragInput, dragStart, startPos

frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
    end
end)

frame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

frame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
